pipeline {
    agent any
    
    environment {
        NODEJS_HOME = tool name: 'NodeJS-18', type: 'nodejs'
        PATH = "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:${env.NODEJS_HOME}/bin:${env.PATH}"
        DOCKER_HOST = "unix:///var/run/docker.sock"
        DOCKER_TAG = "${env.BUILD_ID}"
    }
    
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out code...'
                checkout scm
            }
        }
        
        stage('Setup Environment') {
            steps {
                sh '''
                    node --version
                    docker --version
                    kubectl version --client || echo "kubectl not found"
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                sh '''
                    cd saga-poc/booking-service && npm install
                    cd ../payment-service && npm install
                '''
            }
        }
        
        stage('Build Docker Images') {
            steps {
                sh '''
                    cd saga-poc/booking-service
                    docker build -t booking-service:${DOCKER_TAG} .
                    docker tag booking-service:${DOCKER_TAG} booking-service:latest
                    cd ../..
                    
                    cd saga-poc/payment-service
                    docker build -t payment-service:${DOCKER_TAG} .
                    docker tag payment-service:${DOCKER_TAG} payment-service:latest
                    cd ../..
                '''
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin
                        
                        docker tag booking-service:latest ${DOCKER_USERNAME}/booking-service:latest
                        docker tag booking-service:${DOCKER_TAG} ${DOCKER_USERNAME}/booking-service:${DOCKER_TAG}
                        docker push ${DOCKER_USERNAME}/booking-service:latest
                        docker push ${DOCKER_USERNAME}/booking-service:${DOCKER_TAG}
                        
                        docker tag payment-service:latest ${DOCKER_USERNAME}/payment-service:latest
                        docker tag payment-service:${DOCKER_TAG} ${DOCKER_USERNAME}/payment-service:${DOCKER_TAG}
                        docker push ${DOCKER_USERNAME}/payment-service:latest
                        docker push ${DOCKER_USERNAME}/payment-service:${DOCKER_TAG}
                        
                        echo "✅ Images pushed to Docker Hub!"
                    '''
                }
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                echo '☸️ Deploying to Kubernetes...'
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        # Ensure namespace exists
                        kubectl create namespace saga --dry-run=client -o yaml | kubectl apply -f -
                        
                        # Deploy services
                        kubectl apply -f saga-poc/booking-service/k8s/booking-service.yaml
                        kubectl apply -f saga-poc/payment-service/k8s/payment-service.yaml
                        
                        # Wait for deployments to be ready
                        echo "⏳ Waiting for booking-service..."
                        kubectl rollout status deployment/booking-service -n saga --timeout=120s || echo "Booking service not ready"
                        
                        echo "⏳ Waiting for payment-service..."
                        kubectl rollout status deployment/payment-service -n saga --timeout=120s || echo "Payment service not ready"
                        
                        # Show status
                        echo "📊 Deployment Status:"
                        kubectl get pods,svc,deploy -n saga
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo '🎉 Pipeline SUCCESS!'
            echo '✅ Images pushed to Docker Hub'
            echo '✅ Deployed to Kubernetes'
            echo ''
            echo '📊 To access services:'
            echo '  kubectl port-forward -n saga svc/booking-service 3001:3001'
            echo '  kubectl port-forward -n saga svc/payment-service 3002:3002'
        }
        failure {
            echo '❌ Pipeline failed!'
            echo 'Check logs above for details'
        }
    }
}