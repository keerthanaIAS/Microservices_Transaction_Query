pipeline {
    agent any
    
    environment {
        NODEJS_HOME = tool name: 'NodeJS-18', type: 'nodejs'
        PATH = "${env.NODEJS_HOME}/bin:${env.PATH}"
    }
    
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out code...'
                checkout scm
                sh '''
                    echo "Current directory: $(pwd)"
                    echo "Files:"
                    ls -la
                '''
            }
        }
        
        stage('Setup Environment') {
            steps {
                echo '🔧 Setting up environment...'
                sh '''
                    echo "Node.js version:"
                    node --version
                    
                    echo "npm version:"
                    npm --version
                    
                    echo "Docker version:"
                    docker --version || echo "Docker not found"
                    
                    echo "Docker Compose version:"
                    docker-compose --version || echo "Docker Compose not found"
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📦 Installing dependencies...'
                sh '''
                    # Create logs directory
                    mkdir -p logs
                    
                    # Go to saga-poc folder where your code is
                    cd saga-poc
                    
                    echo "Installing booking-service dependencies..."
                    cd booking-service
                    npm install
                    cd ..
                    
                    echo "Installing payment-service dependencies..."
                    cd payment-service
                    npm install
                    cd ..
                    
                    echo "✅ Dependencies installed"
                '''
            }
        }
        
        stage('Check Docker Status') {
            steps {
                echo '🐳 Checking Docker containers...'
                sh '''
                    echo "Running containers:"
                    docker ps
                    
                    echo ""
                    echo "Checking MongoDB..."
                    docker exec mongo mongosh --port 27017 --eval "db.adminCommand('ping')" || echo "⚠️ MongoDB not ready"
                    
                    echo ""
                    echo "Checking Kafka..."
                    docker exec kafka kafka-topics --list --bootstrap-server localhost:9092 || echo "⚠️ Kafka not ready"
                '''
            }
        }
        
        stage('Create Kafka Topics') {
            steps {
                echo '📨 Creating Kafka topics...'
                sh '''
                    cd saga-poc
                    
                    echo "Creating booking-events topic..."
                    docker exec kafka kafka-topics --create --topic booking-events \
                        --bootstrap-server localhost:9092 \
                        --partitions 3 --replication-factor 1 || echo "Topic may already exist"
                    
                    echo "Creating payment-events topic..."
                    docker exec kafka kafka-topics --create --topic payment-events \
                        --bootstrap-server localhost:9092 \
                        --partitions 3 --replication-factor 1 || echo "Topic may already exist"
                    
                    echo "Available topics:"
                    docker exec kafka kafka-topics --list --bootstrap-server localhost:9092
                '''
            }
        }
        
        stage('Start Services') {
            steps {
                echo '🚀 Starting microservices...'
                sh '''
                    # Kill any existing node processes
                    echo "Cleaning up old processes..."
                    pkill -f "node.*booking-service" || true
                    pkill -f "node.*payment-service" || true
                    
                    cd saga-poc
                    
                    # Start booking service
                    echo "Starting Booking Service on port 3001..."
                    cd booking-service
                    nohup npm start > ../logs/booking-service.log 2>&1 &
                    echo $! > ../logs/booking-service.pid
                    cd ..
                    
                    # Start payment service
                    echo "Starting Payment Service on port 3002..."
                    cd payment-service
                    nohup npm start > ../logs/payment-service.log 2>&1 &
                    echo $! > ../logs/payment-service.pid
                    cd ..
                    
                    echo "⏳ Waiting for services to start (25 seconds)..."
                    sleep 25
                    
                    echo "Running Node processes:"
                    ps aux | grep node | grep -v grep || echo "No node processes found"
                '''
            }
        }
        
        stage('Health Check') {
            steps {
                echo '🏥 Running health checks...'
                sh '''
                    echo "Checking Booking Service..."
                    curl -s -o /dev/null -w "Booking Service: %{http_code}\n" http://localhost:3001/api/bookings || echo "❌ Booking service not ready"
                    
                    echo "Checking Payment Service..."
                    curl -s -o /dev/null -w "Payment Service: %{http_code}\n" http://localhost:3002/api/payments || echo "❌ Payment service not ready"
                    
                    echo "Checking MongoDB UI..."
                    curl -s -o /dev/null -w "MongoDB UI: %{http_code}\n" http://localhost:8081 || echo "❌ MongoDB UI not ready"
                '''
            }
        }
        
        stage('Smoke Test') {
            steps {
                echo '🧪 Running smoke test...'
                sh '''
                    echo "Creating test booking..."
                    curl -X POST http://localhost:3001/api/bookings \
                        -H "Content-Type: application/json" \
                        -d '{"userId":"jenkins_test","amount":99.99}' \
                        -w "\nStatus: %{http_code}\n"
                    
                    echo ""
                    echo "⏳ Waiting for processing (10 seconds)..."
                    sleep 10
                    
                    echo "Fetching all bookings..."
                    curl -s http://localhost:3001/api/bookings
                    
                    echo ""
                    echo "Fetching all payments..."
                    curl -s http://localhost:3002/api/payments
                '''
            }
        }
        
        stage('Show Service Logs') {
            steps {
                echo '📋 Showing service logs...'
                sh '''
                    cd saga-poc
                    
                    echo "===== Booking Service Logs (last 20 lines) ====="
                    tail -20 logs/booking-service.log 2>/dev/null || echo "No logs found"
                    echo ""
                    
                    echo "===== Payment Service Logs (last 20 lines) ====="
                    tail -20 logs/payment-service.log 2>/dev/null || echo "No logs found"
                '''
            }
        }
    }
    
    post {
        success {
            echo '🎉 Pipeline completed successfully!'
            echo ''
            echo '✅ Services are running:'
            echo '  - Booking Service: http://localhost:3001'
            echo '  - Payment Service: http://localhost:3002'
            echo '  - MongoDB UI: http://localhost:8081'
        }
        
        failure {
            echo '❌ Pipeline failed!'
            echo '🔍 Check the logs above for errors'
        }
    }
}