pipeline {
    agent any
    
    environment {
        NODEJS_HOME = tool name: 'NodeJS-18', type: 'nodejs'
        PATH = "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:${env.NODEJS_HOME}/bin:${env.PATH}"
        DOCKER_HOST = "unix:///var/run/docker.sock"
        
        // Docker Hub configuration (without DOCKER_USERNAME)
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_TAG = "${env.BUILD_ID}"
        DOCKER_LATEST = "latest"
        
        // Kubernetes configuration
        KUBECONFIG = '/Users/keerthana/.kube/config'
        K8S_NAMESPACE = 'saga'
    }
    
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out code...'
                checkout scm
                sh 'pwd && ls -la'
            }
        }
        
        stage('Setup Environment') {
            steps {
                echo '🔧 Setting up environment...'
                sh '''
                    echo "Node.js version:"
                    node --version
                    
                    echo "npm version:"
                    npm --version
                    
                    echo "Docker version:"
                    docker --version
                    
                    echo "kubectl version:"
                    kubectl version --client || echo "kubectl not found"
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📦 Installing dependencies...'
                sh '''
                    mkdir -p logs
                    cd saga-poc
                    
                    echo "Installing booking-service dependencies..."
                    cd booking-service && npm install && cd ..
                    
                    echo "Installing payment-service dependencies..."
                    cd payment-service && npm install && cd ..
                    
                    echo "✅ Dependencies installed"
                '''
            }
        }
        
        stage('Build Docker Images') {
            steps {
                echo '🐳 Building Docker images...'
                script {
                    sh '''
                        cd saga-poc/booking-service
                        docker build -t booking-service:${DOCKER_TAG} .
                        docker tag booking-service:${DOCKER_TAG} booking-service:${DOCKER_LATEST}
                        cd ../..
                    '''
                    
                    sh '''
                        cd saga-poc/payment-service
                        docker build -t payment-service:${DOCKER_TAG} .
                        docker tag payment-service:${DOCKER_TAG} payment-service:${DOCKER_LATEST}
                        cd ../..
                    '''
                    
                    echo "✅ Docker images built successfully"
                }
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                echo '📤 Pushing images to Docker Hub...'
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        echo "Logging in to Docker Hub..."
                        echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin
                        
                        echo "Tagging and pushing booking-service..."
                        docker tag booking-service:latest ${DOCKER_USERNAME}/booking-service:latest
                        docker tag booking-service:${DOCKER_TAG} ${DOCKER_USERNAME}/booking-service:${DOCKER_TAG}
                        docker push ${DOCKER_USERNAME}/booking-service:latest
                        docker push ${DOCKER_USERNAME}/booking-service:${DOCKER_TAG}
                        
                        echo "Tagging and pushing payment-service..."
                        docker tag payment-service:latest ${DOCKER_USERNAME}/payment-service:latest
                        docker tag payment-service:${DOCKER_TAG} ${DOCKER_USERNAME}/payment-service:${DOCKER_TAG}
                        docker push ${DOCKER_USERNAME}/payment-service:latest
                        docker push ${DOCKER_USERNAME}/payment-service:${DOCKER_TAG}
                        
                        echo "✅ Images pushed to Docker Hub"
                    '''
                }
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                echo '☸️ Deploying to Kubernetes...'
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        # Update YAML with correct username
                        sed -i "s|YOUR_DOCKER_USERNAME|${DOCKER_USERNAME}|g" saga-poc/k8s/*.yaml
                        
                        # Create namespace
                        kubectl create namespace ${K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                        
                        # Apply Kubernetes manifests
                        echo "Applying Kubernetes configurations..."
                        kubectl apply -f saga-poc/k8s/namespace.yaml
                        kubectl apply -f saga-poc/k8s/booking-service.yaml
                        kubectl apply -f saga-poc/k8s/payment-service.yaml
                        
                        # Wait for deployments
                        echo "Waiting for deployments to be ready..."
                        kubectl rollout status deployment/booking-service -n ${K8S_NAMESPACE} --timeout=60s || echo "Booking service not ready"
                        kubectl rollout status deployment/payment-service -n ${K8S_NAMESPACE} --timeout=60s || echo "Payment service not ready"
                        
                        echo "Services status:"
                        kubectl get pods,svc,deploy -n ${K8S_NAMESPACE}
                    '''
                }
            }
        }
        
        stage('Health Check') {
            steps {
                echo '🏥 Running health checks...'
                sh '''
                    echo "Checking Booking Service..."
                    curl -s -o /dev/null -w "Booking Service: %{http_code}\n" http://localhost:3001/api/bookings || echo "❌ Booking service not ready"
                    
                    echo "Checking Payment Service..."
                    curl -s -o /dev/null -w "Payment Service: %{http_code}\n" http://localhost:3002/api/payments || echo "❌ Payment service not ready"
                '''
            }
        }
        
        stage('Smoke Test') {
            steps {
                echo '🧪 Running smoke test...'
                sh '''
                    echo "Creating test booking..."
                    curl -X POST http://localhost:3001/api/bookings \
                        -H "Content-Type: application/json" \
                        -d '{"userId":"jenkins_test","amount":99.99}' \
                        -w "\nStatus: %{http_code}\n"
                    
                    sleep 5
                    
                    echo "Fetching bookings..."
                    curl -s http://localhost:3001/api/bookings
                    
                    echo "Fetching payments..."
                    curl -s http://localhost:3002/api/payments
                '''
            }
        }
    }
    
    post {
        success {
            echo '🎉 Pipeline completed successfully!'
            echo '✅ Images pushed to Docker Hub'
            echo '✅ Services deployed to Kubernetes'
        }
        
        failure {
            echo '❌ Pipeline failed!'
            echo 'Check logs above for errors'
        }
    }
}